generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VISITOR
  VOLUNTEER
  COMMITTEE
  ADMIN
}

enum PassStatus {
  VALID
  SCANNED
  EXPIRED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EmergencyType {
  MEDICAL
  LOST_CHILD
  FIRE
  SUSPICIOUS_ACTIVITY
  TECHNICAL
  OTHER
}

enum EmergencyStatus {
  REPORTED
  ACKNOWLEDGED
  RESOLVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  name         String
  role         Role     @default(VISITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings      Booking[]
  donations     Donation[]
  assignedTasks VolunteerTask[] @relation("AssignedTasks")
  emergencies   Emergency[]     @relation("ReportedEmergencies")
}

model Festival {
  id          String   @id @default(uuid())
  name        String
  year        Int
  startDate   DateTime
  endDate     DateTime
  description String?

  events Event[]
}

model Event {
  id          String   @id @default(uuid())
  festivalId  String
  title       String
  venue       String
  time        DateTime
  description String?
  capacity    Int

  festival Festival  @relation(fields: [festivalId], references: [id])
  bookings Booking[]
}

model Booking {
  id          String     @id @default(uuid())
  userId      String
  eventId     String
  date        DateTime
  gateNumber  Int
  qrCodeHash  String     @unique
  status      PassStatus @default(VALID)
  entryTime   DateTime?
  scannedById String?

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
}

model Donation {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  transactionId String   @unique
  status        String   @default("SUCCESS")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model VolunteerTask {
  id            String     @id @default(uuid())
  assigneeId    String
  title         String
  taskType      String
  location      String
  reportingTime DateTime
  status        TaskStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  assignee User @relation("AssignedTasks", fields: [assigneeId], references: [id])
}

model Emergency {
  id           String          @id @default(uuid())
  type         EmergencyType
  location     String
  reportedById String
  status       EmergencyStatus @default(REPORTED)
  createdAt    DateTime        @default(now())
  resolvedAt   DateTime?

  reportedBy User @relation("ReportedEmergencies", fields: [reportedById], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   String
  timestamp DateTime @default(now())
}
